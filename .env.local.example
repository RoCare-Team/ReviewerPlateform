# Copy to .env.local and fill in. .env* is gitignored — never commit the real file.

# --- Core ---------------------------------------------------------------
# openssl rand -base64 32
AUTH_SECRET=
APP_URL=http://localhost:3000

# --- Database -----------------------------------------------------------
MONGODB_URI=mongodb://127.0.0.1:27017/reviewhub

# --- Google OAuth (sign-in identity ONLY) -------------------------------
# Scope is openid/email/profile. This is NOT the Google Business Profile
# connection — GBP needs its own client, its own consent screen, and the
# business.manage scope. Do not reuse these credentials for it.
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- SMTP (OTP + password reset) ----------------------------------------
# Leave SMTP_HOST empty in dev and codes print to the server console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="ReviewHub <no-reply@reviewhub.in>"
